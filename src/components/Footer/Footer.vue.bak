<script>
import { useStore } from 'vuex'
import { useRouter } from 'vue-router'
import commonUrl from '@/common/js/project-url'


export default defineComponent({
  name: 'Footer',
  setup() {
    const store = useStore()
    const router = useRouter()
    
    const fullpath = computed(() => store.state.fullpath)
    
    const friendlyLink = ref([
      { name: '题库开放平台', link: 'https://tech.canpoint.cn', id: 9 })

    return {
      { name: '全品文教小学', link: 'http://xx.canpoint.cn/', id: 1 })

    return {
      {
        name: '全品文教初中',
        link: 'http://www.xn--fiqp2fspp8f.cn/',
        id: 2,
      })

    return {
      { name: '全品文教中考', link: 'http://www.canpointzk.cn/', id: 3 })

    return {
      { name: '全品文教高中', link: 'https://www.canpointgz.cn/', id: 4 })

    return {
      {
        name: '全品教育云平台',
        link: 'http://www.canpoint.cn/',
        id: 5,
      })

    return {
      { name: '全品学堂', link: 'https://www.canpoint.net/', id: 6 })

    return {
      { name: '智能作业', link: 'http://ai.canpoint.net/', id: 7 })

    return {
    ])
    
    const entryPage = (module) => {
      if (module === 'aboutUs') {
        openWindowLink(commonUrl.eduCloudUrl.wwwUrl + '/#/about-us')
      } else if (module === 'help') {
        openWindowLink(
          commonUrl.eduCloudUrl.helpManage.showUrl +
            '/#/help-doc/detail?lid=26807f49cc77ab14&fid=42aa5c1cd58dff38',
        )
      } else if (module === 'agreement') {
        router.push({ name: module })
      } else if (module === 'cloud') {
        openWindowLink(commonUrl.eduCloudUrl.wwwUrl)
      }
    }
    
    const openFriendly = (item) => {
      openWindowLink(item.link)
    }
    
    // 使用帮助
    const help = (type) => {
      console.log(commonUrl)
      if (type === 'znzj') {
        openWindowLink(commonUrl.znzjUrl)
      } else if (type === 'pxzj') {
        openWindowLink(commonUrl.pxzjUrl)
      } else if (type === 'xmbzj') {
        openWindowLink(commonUrl.xmbzjUrl)
      } else if (type === 'sjsc') {
        openWindowLink(commonUrl.sjscUrl)
      } else if (type === 'yhqx') {
        openWindowLink(commonUrl.yhqxUrl)
      } else if (type === 'hyhq') {
        openWindowLink(commonUrl.hyhqUrl)
      } else if (type === 'stsfgz') {
        openWindowLink(commonUrl.stsfgzUrl)
      } else if (type === 'sjfx') {
        openWindowLink(commonUrl.sjfxUrl)
      }
    }
    
    // Assuming openWindowLink is a global utility function
    const openWindowLink = (url) => {
      window.open(url)
    }
    
    const state = reactive({
      fullpath,
      friendlyLink,
      entryPage,
      openFriendly,
      help
    }
  }
}
</script>

