  margin-bottom: 20px;
  position: relative;

  &:hover {
    border: 1px solid #487FFF;
    border-radius: 6px;

    .delete-item {
      position: absolute;
      color: $color-theme-l;
      font-size: 16px;
      top: 0;
      right: 0;
      display: none;
    }
  }

  .paper-title {
    display: inline-block;
    max-width: 450px;
