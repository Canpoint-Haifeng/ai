  .radio-label-item {
    display: inline-block;
    margin-bottom: 20px;
    .icon {
      vertical-align: middle;
    }
  }
}
.form-item-radio:nth-child(3) {
  .radio-label-item {
    display: inline-block;
    margin-bottom: 14px;
    .text {
      color: $color-text-l;
    }
  }
}
