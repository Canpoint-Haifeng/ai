  cursor: pointer;
  &:hover {
    color: $color-theme-d;
  }
}
.pay-box {
  text-align: center;
  .pay-title {
    margin: 22px 0 15px 0;
    .price {
      color: $color-theme-l;
    }
  }
  .pay-qpcoin {
    margin-bottom: 8px;
    .iconcoin {
      margin-right: 8px;
      font-size: $font-size-medium;
    }
    .qpcoin {
      color: $color-theme-l;
    }
  }
  .pay-method {
    margin-bottom: 12px;
  }
  .pay-qrcode {
    display: inline-block;
    width: 140px;
    height: 140px;
    border: 1px dashed $color-theme;
    padding: 10px;
    margin-bottom: 12px;
    box-sizing: border-box;
    .qrcode-img {
      width: 100%;
      height: 100%;
    }
  }
  .pay-tips {
    line-height: 20px;
    .text:last-child {
      margin-top: 5px;
    }
  }
}
.coin-box {
  .coin-title {
    margin: 22px 0 38px 0;
    .price {
      color: $color-theme-l;
    }
  }
  .coin-item {
    width: 100%;
    height: 40px;
    line-height: 40px;
    background: #f0f5fd;
    border: 1px dashed $color-theme;
    box-sizing: border-box;
    margin-bottom: 20px;
    padding: 0 12px;
    color: $color-text;
    .iconcoin {
      margin-right: 8px;
      font-size: $font-size-medium;
    }
    .qpcoin {
      color: $color-theme-l;
    }
    &:nth-child(2) {
      background: #fff3f2;
      border: 1px dashed $color-theme-l;
    }
  }
  .coin-tips {
    line-height: 20px;
    .text:nth-child(2) {
      padding-left: 25px;
    }
    .text:last-child {
      margin-top: 45px;
    }
  }
}
.succss-box {
  margin: 80px 18px;
  text-align: center;
  .icon-box {
    display: inline-block;
    width: 40px;
    height: 40px;
    margin-bottom: 30px;
    .iconsuccess {
      color: #7ac23c;
      font-size: 40px;
    }
  }
  .text1 {
