<template>
  <div class="category-content">
    <label class="category-label">{{ categoryLabel }}</label>
    <div class="paper-times-picker">
      <el-date-picker
        v-model="currTimesCode"
        type="daterange"
        value-format="yyyy-MM-dd"
        format="yyyy/MM/dd"
        range-separator="-"
        prefix-icon=" "
        start-placeholder="开始日期"
        size="mini"
        end-placeholder="结束日期"
        @change="selectTimes"
      />
    </div>
  </div>
</template>

<script>
  import { defineComponent, ref, reactive, computed, onMounted, watch } from "vue"

export default defineComponent({
    name: 'PaperTimes',
    props: {
      categoryLabel: {
        type: String,
        default: '时间',
      })

    return {
    })

    return {
    setup() {
      const state = reactive({
        currTimesCode: 0,
        gradesList: [],
      }
    })

    return {
    methods: {
      selectTimes(item) {
        if (item) {
          this.$emit('selectTimes', item)
        } else {
          this.$emit('selectTimes', ['', ''])
        }
      })

    return {
    })

    return {
  }
</script>

