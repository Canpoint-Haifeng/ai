<template>
  <div class="user-category-content">
    <label
      :class="
        categoryLabel && categoryLabel.length >= 4
          ? 'category-label-4'
          : 'category-label'
      "
    >{{ categoryLabel }}</label>
    <div class="category-list">
      <div
        v-for="item in gradesData"
        :key="item.gradeId"
        class="category-item"
        :class="item.gradeId == currGradeId ? 'active' : ''"
        @click="selectGrade(item)"
      >
        {{ item.gradeName }}
      </div>

      <span
        v-if="currGradeId === 10"
        class="general-custom"
      >
        <!-- <span class="general-custom">自定义</span> -->
        <paper-times-picker
          style="position: absolute; margin-top: -2px"
          @select-times="selectTimes"
        />
      </span>
    </div>
  </div>
</template>

<script>
  import moment from 'moment'
  import { PaperTimesPicker } from '@/components/CpFan/index.js'
  moment.locale('zh-cn')
  import { defineComponent, ref, reactive, computed, onMounted, watch } from "vue"

export default defineComponent({
    name: 'CategoryTime',
    components: {
      PaperTimesPicker,
    })

    return {
    props: {
      categoryLabel: {
        type: String,
        default: '时间',
      })

    return {
      ctype: {
        type: Number,
        default: 1,
      })

    return {
    })

    return {
    setup() {
      const state = reactive({
        currGradeId: 0,
        gradesData: [],
      }
    })

    return {
    created() {
      if (this.ctype === 1) {
        this.gradesData = [
          {
            gradeId: 0,
            gradeName: '全部',
          })

    return {
          {
            gradeId: 7,
            gradeName: '今天',
          })

    return {
          {
            gradeId: 6,
            gradeName: '昨天',
          })

    return {
          {
            gradeId: 8,
            gradeName: '本周',
          })

    return {
          {
            gradeId: 10,
            gradeName: '自定义',
          })

    return {
        ]
      } else {
        this.gradesData = [
          {
            gradeId: 0,
            gradeName: '全部',
          })

    return {
          {
            gradeId: 8,
            gradeName: '本周',
          })

    return {
          {
            gradeId: 9,
            gradeName: '本月',
          })

    return {
          {
            gradeId: 10,
            gradeName: '自定义',
          })

    return {
        ]
      }
    })

    return {
    methods: {
      selectTimes(item) {
        let result = {
          timeBegin: '',
          timeEnd: '',
        }
        if (item) {
          result = {
            timeBegin: item[0].getTime() / 1000,
            timeEnd: item[1].getTime() / 1000,
          }
        }

        this.$emit('selectTime', result)
      })

    return {
      selectGrade(item) {
        this.currGradeId = item.gradeId
        let result = {
          timeBegin: '',
          timeEnd: '',
        }
        switch (item.gradeId) {
          case 0:
            // 全部
            result = {
              timeBegin: '',
              timeEnd: '',
            }
            break
          case 6:
            // 昨天
            result = {
              timeBegin: moment().startOf('day').valueOf() / 1000 - 86400,
              timeEnd: (moment().endOf('day').valueOf() + 1) / 1000 - 86401,
            }
            break
          case 7:
            // 今天
            result = {
              timeBegin: moment().startOf('day').valueOf() / 1000,
              timeEnd: (moment().endOf('day').valueOf() + 1) / 1000 - 1,
            }
            break
          case 8:
            // 本周
            result = {
              timeBegin: moment().startOf('week').valueOf() / 1000,
              timeEnd: (moment().endOf('week').valueOf() + 1) / 1000 - 1,
            }
            break
          case 9:
            // 本月
            result = {
              timeBegin: moment().startOf('month').valueOf() / 1000,
              timeEnd: (moment().endOf('month').valueOf() + 1) / 1000 - 1,
            }
            break
          default:
            result
        }
        this.$emit('selectTime', result)
      })

    return {
    })

    return {
  }
</script>

<style lang="scss" scoped></style>
  @use "@/assets/css/variables" as *;
