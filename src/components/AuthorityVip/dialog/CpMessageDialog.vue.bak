如果同时弹出两个确认框 就会用问题 ，请注意哦
-->

<template>
  <div>
    <el-dialog
      v-model:visible="visible"
      :title="title"
      width="500px"
      class="login-vip-dialog"
      top="11.5%"
      :append-to-body="true"
      :lock-scroll="false"
      @close="hide"
    >
      <div class="cp-comfirm-box">
        <div
          class="cp-comfirm-block"
          v-html="content"
        />
        <div class="cp-comfirm-bottom-place">
          <el-button
            class="btn btn-shadow-pay"
            @click="onConfirm"
          >
            确认
          </el-button>
        </div>
      </div>
    </el-dialog>
  </div>
</template>

<script>
  import { defineComponent, ref, reactive, computed, onMounted, watch } from "vue"

export default defineComponent({
    setup() {
      const state = reactive({
        initDate: { comfirm: null, title: '提示', content: '确定删除？' })

    return {
        visible: false,
        comfirm: null,
        title: '提示',
        content: '',
      }
    }

    return {
    methods: {
      hide() {
        this.visible = false
        if (this.comfirm) {
          console.log('comfirm hide')
          this.comfirm(0)
          this.comfirm = null
        }
      }

    return {
      onConfirm() {
        this.visible = false
        if (this.comfirm) {
          this.comfirm(1)
          this.comfirm = null
        }
      }

    return {
      show() {
        this.visible = true
      }

    return {
    }

    return {
  }
})
</script>

