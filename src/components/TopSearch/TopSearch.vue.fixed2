          <div class="container">
            <div class="home-search-input">
              <div class="tab-btn">
                <template v-for="item in searchOptions" :key="item.label">
                  <div
                    class="btns"
                    @mousedown="event => handleCommand(event, item)"
                    :class="{ 'active-btn': currSearchOption === item.label }"
                  >
                    {{ item.name }}
                  </div>
                </template>
              </div>
              <el-input
                popper-class="search-autocomplete-suggestions custom-dropdown-menu"
                v-model="searchText"
                placeholder="请输入搜索内容"
                @keyup.enter="search"
                clearable
                class="search-input"
              >
              </el-input>
              <!-- <HistoryMessageList
                :searchText="searchText"
