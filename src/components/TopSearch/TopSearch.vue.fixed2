<script>
import CTS from '@/common/js/constant'
import { API } from '@/api/config'
import { mapState } from 'vuex'
import HistoryMessageList from './HistoryMessageList.vue'
import userCenterPopover from './userCenterPopover.vue'
import {
  isLogin,
  getToken,
  removeToken,
  removeSessionStore,
} from '@/common/js/util'

export default {
  components: {
    HistoryMessageList,
    userCenterPopover,
  },
  data() {
    return {
      loginStatus: false,
      searchText: '',
      isShowHis: false,
      isShowHot: false,
      currSearchOption: 'paper',
      searchOptions: [
        {
          name: '试卷',
          label: 'paper',
        },
        {
          name: '试题',
          label: 'question',
        },
        {
          name: '教材',
          label: 'book',
        },
      ],
    }
  },
  computed: {
    ...mapState(['userInfo']),
  },
  mounted() {
    this.loginStatus = isLogin()
  },
  methods: {
    // 显示登录弹框
    showLogin() {
      this.$refs.appLogin.showLogin()
    },
    // 显示注册弹框
    showRegister() {
      this.$refs.appLogin.showRegister()
    },
    // 退出登录
    logout() {
      let parms = {
        token: getToken(),
      }
      this.wayPost(API.LOGOUT, parms).then((res) => {
        if (res.code === CTS.constant.SUCCESS_CODE) {
          removeToken()
          removeSessionStore('serviceInfo')
          this.loginStatus = false
          window.location.reload() // 刷新页面
        }
      })
    },
    // 帮助中心
    helpCenter() {
      window.open(
        'http://help.canpoint.cn/#/help-doc/detail?lid=26807f49cc77ab14&fid=0aaed09d31b46cba',
      )
    },
    // 搜索
    search() {
      if (!this.searchText) {
        this.$message.warning('请输入搜索内容')
        return
      }
      this.isShowHis = false
      this.isShowHot = false
      if (this.currSearchOption === 'paper') {
        this.$router.push({
          path: '/search-result/search-paper',
          query: {
            searchText: this.searchText,
          },
        })
      } else if (this.currSearchOption === 'question') {
        this.$router.push({
          path: '/search-result/search-question',
          query: {
            searchText: this.searchText,
          },
        })
      } else if (this.currSearchOption === 'book') {
        this.$router.push({
          path: '/search-result/search-book',
          query: {
            searchText: this.searchText,
          },
        })
      }
    },
    // 切换搜索类型
    handleCommand(event, item) {
      this.currSearchOption = item.label
      this.isShowHis = false
      this.isShowHot = false
    },
    // 修改搜索内容
    changeHisText(text) {
      this.searchText = text
      this.isShowHis = false
      this.search()
    },
    // 修改搜索内容
    changeHotPaper(text) {
      this.searchText = text
      this.isShowHot = false
      this.search()
    },
    // 进入上传页面
    entryUpload() {
      this.$router.push({
        path: '/paper-upload',
      })
    },
  },
}
</script>

