</template>

<script>
import echarts from 'echarts'
import PieEcharts from '@/components/ECharts/Pie'
import { setpieOptions } from '@/common/config/pieOptions'
import { dealDecimal } from '@/common/js/util'
import { pieOptions1, pieOptions2, pieOptions3, barOptions } from './options'
import bar from '@/components/ECharts/line-bar.vue'
export default {
  components: {
    PieEcharts,
    bar,
  },
  props: {
    questionAnalysis: {
      type: Object,
      default() {
        return {}
      },
    },
  },
  data() {
    return {
      marks: {
        0: '1',
        20: '0.8',
        40: '0.6',
        60: '0.4',
        80: '0.2',
        100: '0',
      },
      text: ['容易', '较易', '中等', '较难', '困难'],
      seting: [
        { label: '容易', value: 0, type: 'easy_num' },
        { label: '较易', value: 0, type: 'little_easy_num' },
        { label: '中等', value: 0, type: 'middle_num' },
        { label: '较难', value: 0, type: 'little_hard_num' },
        { label: '困难', value: 0, type: 'hard_num' },
      ],
      analysisDialog: {
        title: '组卷分析',
        visible: false,
        width: '800px',
      },
      showFixed: false,
      activeName: 'first',
      barOptions: {},
      pieOptions1,
      pieOptions2,
      pieOptions3,
      pieData1: [],
      pieData2: [],
      pieData3: [],
      pointListTable: [],
      spanArr: [],
      diffculty: 0.5,
    }
  },
  watch: {
    questionAnalysis() {
      this.initPies()
      let num = 0
      this.questionAnalysis.questionDifficultChartList.forEach(v => {
        this.seting[v.questionDifficult - 1].value = v.count
        num += v.count*[0.9, 0.7, 0.5, 0.3, 0.1][v.questionDifficult - 1]
      
      })
      this.diffculty = (num / this.questionAnalysis.paperTotalCount).toFixed(2)
    
    },
  },
  created() {
    // this.initPies()
  },
  mounted() {
  },
  methods: {
    handleClose(done) {
      done();
    },
    useGroupCatelogue() {
      if (this.questionAnalysis.paperIdEnc && this.questionAnalysis.source) {
        this.$router.push({
          path: '/paper/intelligence/paperbreakdowngroup',
          query: {
            paperIdEnc: this.questionAnalysis.paperIdEnc,
            source: this.questionAnalysis.source,
          },
        })
      } else {
        this.$store.dispatch(
          'updataPaperGroupCatalogue',
          this.questionAnalysis.paperGroupCatalogue,
        )
        this.$router.push({
          path: '/paper/intelligence/paperbreakdowngroup',
          query: { type: 3 },
        })
      }
    },
    initPies() {
      const totalCount = this.questionAnalysis.paperTotalCount
      this.questionAnalysis.paperTotalScore = dealDecimal(
        this.questionAnalysis.paperTotalScore,
        1,
      )

      const totalScore = this.questionAnalysis.paperTotalScore
      if (this.activeName === 'first') {
        // this.pieOptions1 = setpieOptions('题型题量分布', '总题数', totalCount)
        // this.pieOptions2 = setpieOptions('题型分数分布', '总分数', totalScore)
        this.pieData1 = this.questionAnalysis.questionTypeChartList.map(v => {
          return {
            name: v.questionTypeName,
            // value: (item.count / totalCount) * 100,
            value: v.count,
          }
        })
        this.pieData2 = this.questionAnalysis.questionPointChartList.map(v => {
          return {
            name: v.questionPointName,
            value: v.count
          }
        })
        this.pieData3 = this.questionAnalysis.questionPointChartList.map(v => {
          return {
            name: v.questionPointName,
            value: v.score
          }
        })
      }
      // this.initBar()
      this.$nextTick(() => {
        const dom = document.querySelector('.sliderAlone .el-slider__button')
        dom.innerText = this.diffculty
      })
    },
    initBar() {
      this.barOptions = barOptions
      this.barOptions.xAxis.data = []
      this.barOptions.series[0].data = []
      this.barOptions.series[1].data = []
      console.log(this.questionAnalysis.questionPointChartList)
      this.questionAnalysis.questionPointChartList.forEach(v => {
        this.barOptions.xAxis.data.push(v.questionPointName)
        this.barOptions.series[0].data.push(v.count)
        this.barOptions.series[1].data.push(v.score)
      })
      this.barOptions.series[1].itemStyle.color = '#22e4ff'
      this.$nextTick(() => {
        const chart = echarts.init(document.querySelector('#bar'))
        chart.setOption(this.barOptions)
      })
    },
    // 处理知识点数据列表
    handleQuestionPoint() {
      this.pointListTable = [...this.questionAnalysis.questionPointChartList]
      // const pointList = this.questionAnalysis.questionPointChartList
      // pointList.forEach(item => {
      //   item.list.forEach(subItem => {
      //     this.pointListTable.push({
      //       ...subItem,
      //       count: item.count,
      //       id: item.id,
      //       countScale: item.countScale,
      //       questionPoint: item.questionPoint,
      //       questionPointName: item.questionPointName,
      //       score: item.score,
      //       scoreScale: item.scoreScale,
      //       questions: item.questions
      //     })
      //   })
      // })
      // this.loading = false
      // this.getSpanArr(this.pointListTable)
    },
    // 判断单元格合并条件
    getSpanArr(data) {
      this.spanArr = []
      for (let i = 0; i < data.length; i++) {
        if (i === 0) {
          this.spanArr.push(1)
          this.pos = 0
        } else {
          // 判断当前元素与上一个元素是否相同
          if (data[i].questionPointName === data[i - 1].questionPointName) {
            this.spanArr[this.pos] += 1
            this.spanArr.push(0)
          } else {
            this.spanArr.push(1)
            this.pos = i
          }
        }
      }
    },
    // 合并单元格处理函数
    arraySpanMethod({ rowIndex, columnIndex }) {
      if (columnIndex < 5) {
        const _row = this.spanArr[rowIndex]
        const _col = _row > 0 ? 1 : 0
        return {
          rowspan: _row,
          colspan: _col,
        }
      }
    },
    // 显示试卷分析提示框
    showDialog() {
      this.analysisDialog.visible = true
    },
    // 隐藏试卷分析提示框
    hideDialog() {
      this.analysisDialog.visible = false
    },
    // 点击tab切换
    handleClick(tabComp) {
      if (tabComp.name === 'second' && !tabComp.isFirst) {
        this.initPies()
        this.handleQuestionPoint()
        tabComp.isFirst = true
      }
    },
    // 监听关闭试卷提示框
    closeAnalysisDialog() {
      this.activeName = 'first'
    },
    forMatToolTip(val) {
      return val / 100
    },
  },
}
</script>

