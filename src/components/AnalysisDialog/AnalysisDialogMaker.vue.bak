                            </div>
                          </template>
                          <div
                            class="knowledge-popover-content"
                            v-html="scope.row.knowledgeNameStr"
                          />
                        </el-tooltip>
                        <!-- <div v-html="scope.row.knowledgeNameStr"></div> -->
                      </template>
