          <el-table-column
            :resizable="false"
            prop="scoreScale"
            min-width="30"
            label="占比"
          >
            <template #default="scope">
              <span v-if="scope.row.scoreScale">{{
                scope.row.scoreScale
              }}</span>
              <span v-else>-</span>
            </template>
          </el-table-column>
          <el-table-column
