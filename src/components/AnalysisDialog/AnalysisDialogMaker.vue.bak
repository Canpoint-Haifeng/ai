                    />详情</span>
                  </h6>
                  <div class="title">
                    知识点&数量
                  </div>
                  <div class="chart">
                    <pie-echarts
                      :options="pieOptions2"
                      :data="pieData2"
                    />
                  </div>
                </div>
              </div>
              <div class="row">
                <div class="item">
                  <!-- <h6>知识点分析</h6>
                  <div id="bar" style="height: 230px"></div> -->
                  <div class="difficultyWrap">
                    <div class="difficulty_title">
                      <div class="title_border">
                        难度分析
                      </div>
                      <span>当前试卷难度（整卷的难度）：<i>{{ diffculty }}</i></span>
                    </div>
                    <div>
                      <div class="flex aloneOption">
                        <div class="sliderAlone">
                          <el-slider
                            class="alone"
                            disabled
                            :value="100*(1-diffculty)"
                            :min="0"
                            :max="100"
                            :show-tooltip="false"
                            :marks="marks"
                            :format-tooltip="forMatToolTip"
                          />
                          <div class="textWrap">
                            <div
                              v-for="(v, i) in text"
                              :key="v"
                            >
                              {{ v }}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <p class="title_border differentiate">
                      区分度
                    </p>
                    <div>
                      <div class="flex">
                        <div class="difficultyLevel">
                          <div class="txt">
                            <span>高</span>
                            <span>低</span>
                          </div>
                          <div class="bar">
                            <i :style="{hight: 30*(questionAnalysis.aaaaaaa || 1)+'%'}" />
                          </div>
                        </div>
                        <div class="sliderShell">
                          <div
                            v-for="(v, i) in seting"
                            :key="i"
                            class="flex sliderWrap"
                          >
                            <div class="label">
                              {{ v.label }}
                            </div>
                            <el-slider
                              disabled
                              :class="`sliderCom slider${i + 1}`"
                              :value="v.value"
                              :show-tooltip="false"
                            />
                            <div class="value">
                              {{ v.value }}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="item">
                  <div class="title">
                    知识点&分数
                  </div>
                  <div class="chart">
                    <pie-echarts
                      :options="pieOptions3"
                      :data="pieData3"
                    />
                  </div>
                </div>
              </div>
            </el-tab-pane>
            <el-tab-pane
              label="试卷细目表"
              name="four"
            >
              <div
                v-if="activeName === 'four'"
                class="analysis-tabs-pane"
              >
                <div class="dialog-table analysis-table-top analysis-table-bottom dialog-table-box">
                  <el-table
                    v-if="questionAnalysis.paperGroupCatalogue"
                    :data="questionAnalysis.paperGroupCatalogue.paperQuestionAttr
                    "
                    class="customer-no-border-table"
                    element-loading-text="加载中..."
                    border
                    style="width: 100%"
                  >
                    <el-table-column
                      :resizable="false"
                      width="80px"
                      type="index"
                      label="题号"
                    >
                      <!-- <template slot-scope="scope">
                          {{scope.$index+1}}
                        </template> -->
