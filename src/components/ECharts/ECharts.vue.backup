<template>
  <div class="echarts-wrapper">
    <div
      v-if="!emptyData"
      class="echarts-content"
    />
    <div
      v-else
      class="echarts-empty"
    >
      <div
        v-if="title.show"
        class="empty-title"
      >
        {{ title.text }}
      </div>
      <div class="empty-text">
        暂无数据！
      </div>
    </div>
  </div>
</template>

<script>
import { ref, onMounted, watch, nextTick } from 'vue'
import * as echarts from 'echarts'
// import ElementResizeDetectorMaker from 'element-resize-detector'

export default {
  name: 'AppEcharts',
  props: {
    data: {
      type: Array,
      default: () => []
    },
    options: {
      type: Object,
      default: () => {}
    },
    title: {
      type: Object,
      default: () => {
        return {
          show: true,
          text: ''
        }
      }
    }
  },
  setup(props, { el }) {
    const emptyData = ref(false)
    const chart = ref(null)
    
    // Watch for data changes
    watch(() => props.data, () => {
      // 创建图表(调用子类方法)
      createChart(chart.value, echarts)
    })
    
    onMounted(() => {
      nextTick(() => {
        // 不存在创建
        if (!chart.value) {
          const element = el.querySelector('.echarts-content')
          element && (chart.value = echarts.init(element))
        }
        // console.log(chart.value);
        // 创建图表(调用子类方法)
        createChart(chart.value, echarts)
        // 自动监听el的resize插件
        // let elementResizeDetector = ElementResizeDetectorMaker({
        //   strategy: 'scroll', // 监听触发策略
        //   callOnAdd: false // 刚添加的时候是否触发, 默认为true
        // })
        // 监听元素的调整尺寸事件
        // elementResizeDetector.listenTo(el, () => {
        //   // 并自动修改元素的尺寸
        //   resize(el.clientWidth, el.clientHeight)
        // })
      })
    })
    
    const render = (options, title = '') => {
      // 设置配置
      if (props.options) {
        // 设置默认样式
        chart.value.setOption(options, {
          notMerge: true, // 是否不跟之前设置的option进行合并，默认为false，即合并
          lazyUpdate: true, // 在设置完option后是否不立即更新图表，默认为false，即立即更新
          silent: true // 阻止调用 setOption 时抛出事件，默认为false，即抛出事件
        })
        // 设置自定义的覆盖样式
        chart.value.setOption(props.options)
      } else {
        chart.value.setOption(options)
      }
    }
    
    // const resize = (width, height) => {
    //   chart.value.resize(width, height)
    // }
    
    return {
      emptyData,
      chart,
      render
    }
  }
}
</script>

<style scoped lang="scss">
@import "@/assets/css/variables.scss";
  .echarts-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    .echarts-content {
      width: 100%;
      height: 100%;
    }
    .echarts-empty {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      .empty-title {
        position: absolute;
        top: 15px;
        left: 20px;
        color: $color-text-d;
        font-weight: 700;
      }
      .empty-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
    }
  }
</style>
