    <div class="hot-new-sync-paper">
      <div class="hot-new-paper">
        <div class="new-paper-content">
          <div class="head">
            <img
              src="./img/new.svg"
              alt=""
            >
          </div>
          <div
            v-for="(item, index) in newsPaperList"
            :key="item.paperId"
            class="paper-item-info"
            :class="{
              'paper-item-info-special': newHoverIndex === index || index <= 0,
              'hover-class': newHoverIndex === index,
            }"
