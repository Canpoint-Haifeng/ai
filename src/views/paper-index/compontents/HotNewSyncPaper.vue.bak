}
.hot-new-sync-paper {
  display: flex;
  justify-content: space-between;
  padding-top: 16px;
  .hot-new-paper {
    width: 100%;
    // height: 360px;
    overflow: hidden;
    display: flex;
  }
  .sync-paper {
    flex: 1;
    // height: 360px;
    background: #ffffff;
    border-radius: 12px;
    margin-left: 16px;
    padding: 14px 20px 20px;
    .tabs {
      :deep(.el-tabs) {
        margin-bottom: 8px;
