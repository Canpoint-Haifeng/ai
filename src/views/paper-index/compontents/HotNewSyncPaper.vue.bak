<script>
import CTS from '@/common/js/constant'
import { API } from '@/api/config'
import { isLogin, setCookieSubjectVolume } from '@/common/js/util'
import { mapState, mapActions } from 'vuex'
import SynchronousTeaching from './SynchronousTeaching'
import { commonData } from '../hooks/index'
import Index from '@/components/AudioPlay/index.vue'
import moment from 'moment'
export default {
  computed: {
    ...mapState(['currSubject', 'allVipDict']),
  },
  components: {
    SynchronousTeaching,
  },
  data() {
    return {
      listData: [],
      newsPaperList: [],
      hotPaperList: [],
      localPaperList: [],
      activeName: '1',
      commonData: [
        {
          type: 'previewNum',
          value: '浏览',
        },
        {
          type: 'downNum',
          value: '下载',
        },
      ],
      hotHoverIndex: -1,
      newHoverIndex: -1,
      lessonType: ['同步教案', '阶段复习', '专题备考'],
      categories: [
        {
          name: '小学',
          subjects: ['语文', '数学', '英语', '科学', '道德与法治'],
        },
        {
          name: '初中',
          subjects: [
            '语文',
            '数学',
            '英语',
            '科学',
            '物理',
            '化学',
            '历史',
            '道德与法治',
            '地理',
            '生物',
            '信息技术',
          ],
        },
        {
          name: '高中',
          subjects: [
            '语文',
            '数学',
            '英语',
            '物理',
            '化学',
            '历史',
            '政治',
            '地理',
            '生物',
          ],
        },
      ],
      selectedSubject: '',
      banner: [
        {
          img: require('./img/bannerl1.png'),
          path: '/paper/center/syncPapers',
        },
        {
          img: require('./img/bannerl1.png'),
          path: '/paper/chapterques/selection',
        },
        {
          img: require('./img/bannerl1.png'),
          path: '/paper/center/syncPapers',
        },
        {
          img: require('./img/bannerl1.png'),
          path: '/paper/center/syncPapers',
        },
        {
          img: require('./img/bannerl1.png'),
          path: '/paper/center/syncPapers',
        },
      ],
      todayData: {
        questionNum: 0,
        lessonNum: 0,
      },
    }
  },
  mounted() {
    this.initHotNewData()
    this.getSubjectList()
    this.apiGet({ urlPath: '/lesson-app/index/today' }).then(res => {
      this.todayData = res.data
    })
  },
  methods: {
    ...mapActions(['updateCurrentSubject']),
    handleClick(tab, event) {
      console.log(tab, event)
    },
    onMorePaper() {
      this.openSystemPathLink('paper/center')
    },
    seeDetail(item) {
      console.log('item', item)
      this.$router.push({
        path: '/smartPaper/prePare',
        query: {
          id: item.id,
          type: item.lessonType,
          source: 1,
        },
      })
      // if(!paperItem.paperId) return
      // let viewCount = paperItem.viewCount || paperItem.totalCountView || 0
      // let queryStr =
      //   '?paperId=' +
      //   paperItem.paperId +
      //   '&source=' +
      //   paperItem.source +
      //   '&viewCount=' +
      //   viewCount +
      //   '&pn=' +
      //   (paperItem.provinceName || '')

      // queryStr += '&subject=' + this.currSubject.subjectCode
      // window.open(this.$router.resolve('/paper/detail').href+queryStr)
    },
    initHotNewData() {
      this.searchPaperList('new', 'newsPaperList')
      this.searchPaperList('hot', 'hotPaperList')
      // this.searchPaperList('rec', 'localPaperList')
      // this.getLocalPaperList()
    },
    async searchPaperList(type, k) {
      let params = {
        stage: this.currSubject.periodCode,
        subject: this.currSubject.subjectCode,
        // sortType: sort,
        pageSize: 5,
        pageNum: 1,
      }
      let urlPath = ''
      if (type === 'new') {
        urlPath = '/lesson-app/index/queryLatestLessons'
      } else if (type === 'hot') {
        urlPath = '/lesson-app/index/queryHotLessons'
      }
      // else if (type === 'rec') {
      //   urlPath = '/lesson-app/index/queryRecommendLessons'
      // }

      try {
        this.apiGet({ urlPath }, params).then(res => {
          console.log('res', res)
          if (res.code === CTS.constant.SUCCESS_CODE) {
            this[k] = res.data.records || []
            console.log(res)

            console.log('hotPaperList', this.hotPaperList)
            console.log('newsPaperList', this.newsPaperList)
          }
        })
      } catch (error) {
        console.log(error)
      }
    },
    getLocalPaperList() {
      // let params = {
      //   stage: this.currSubject.periodCode,
      //   subject: this.currSubject.subjectCode,
      //   pageSize: 3,
      // }
      // this.newPost({urlPath: '/paper-builder/personal/myUpload'}, params).then(res => {
      //   this.localPaperList = res.data.rows || []
      // })
    },
    formatNumber(value) {
      console.log('value', value)
      if (!value) return '0'
      if (value >= 10000) {
        return (value / 10000).toFixed(1) + 'w'
      }
      return value
    },
    showLogin() {
      this.$emit('showLogin')
    },
    formatTimestamp(value, type) {
      if (typeof value === 'number' || /^\d+$/.test(value)) {
        let timestamp = Number(value)

        if (timestamp.toString().length === 10) {
          timestamp *= 1000
        }

        const date = new Date(timestamp)
        if (type == 1) {
          return moment(date).format('YYYY-MM-DD')
        }
        if (isNaN(date.getTime())) {
          return value
        }

        const year = date.getFullYear()
        const month = String(date.getMonth() + 1).padStart(2, '0')
        const day = String(date.getDate()).padStart(2, '0')
        const hours = String(date.getHours()).padStart(2, '0')
        const minutes = String(date.getMinutes()).padStart(2, '0')
        const seconds = String(date.getSeconds()).padStart(2, '0')

        return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`
      }
      return value
    },
    // 更新服务端默认学科
    updateServerSubject(currSubject, isRefresh = true) {
      let parms = {
        stage: currSubject.periodCode,
        subject: currSubject.subjectCode,
      }
      let set = {
        authCode: 2,
      }
      this.apiPost(API.UPDATE_DEFAULT_SUBJECT, parms, set).then(res => {
        if (res.code === CTS.constant.SUCCESS_CODE) {
          setCookieSubjectVolume(currSubject)
          this.updateCurrentSubject(currSubject)
          isRefresh && window.location.reload()
        } else if (res.code === CTS.constant.AUTH_TOKEN_CALLBACK_CODE) {
          // 本地token过期
          this.updateCurrentSubject(currSubject)
          isRefresh && window.location.reload()
        }
      })
    },
    selectSubject(item, subItem) {
      console.log(item, subItem, 111)
      let currSubject = {
        periodCode: item.code || item.id,
        periodName: item.name,
        subjectCode: subItem.code || subItem.id,
        subjectName: subItem.name,
      }
      if (!isLogin()) {
        // 未登录本地无token
        setCookieSubjectVolume(currSubject)
        this.updateCurrentSubject(currSubject)
        window.location.reload()
      } else {
        // 已登录本地有token
        this.updateServerSubject(currSubject)
      }
      // 组卷编辑和组卷预览特殊处理学科切换
    },

    getSubjectList() {
      return this.$store
        .dispatch('getConfigData', { vm: this, type: 2, strParams: {} })
        .then(res => {
          console.log(res)

          this.listData = res || []
        })
    },
    toPaper(v) {
      this.$router.push(v)
    },
    initOutline() {
      const data = {
        stage: this.currSubject.periodCode,
        subject: this.currSubject.subjectCode,
        type: 1,
      }
      this.newPost({ urlPath: '/lesson-app/lessonApp/initOutline' }, data, {
        showLoading: true,
      }).then(res => {
        if (res.code === 200) {
          this.$router.replace(
            `/teachingPlanEdit?id=${res.data}&type=1&manual=1`,
          )
        } else {
          this.$message.error(res.msg)
        }
      })
    },
  },
}
</script>
<style scoped lang="scss">
