<template>
  <li class="paper-item">
    <div class="paper-info">
      <div class="info-left color-9 font-12">
        <h3
          class="paper-title color-3"
          @click="checkPaperDetail(paperItem)"
          v-html="paperItem.latexPaperName || paperItem.paperName"
        />
        <div class="paper-info-part">
          <div class="info">
            <span class="info-item">{{ paperItem.createTime | dateStrBig('YYYY/MM/DD') }}分享</span>

            <span class="info-item">喜欢<em class="text">{{ paperItem.likeCount }}</em></span>
            <span class="info-item">收藏<em class="text">{{ paperItem.collectCount }}</em></span>
            <span class="info-item">已获得<em class="text">{{ paperItem.rewardCount }}</em>下载券</span>
          </div>
          <div
            class="cancel-share"
            @click="cancelShare"
          >
            <span class="iconfont iconshiliangzhinengduixiang2-01" />
            取消分享
          </div>
        </div>
      </div>
      <div class="paper-operate">
        <span
          class="operate-item"
          @click.stop="DownLoadPaper"
        >
          <i class="iconfont iconsoutibaowangyeUIshijueyuansu-15" />
          <div class="t">下载</div>
        </span>

        <SharePaperPopover
          :paper-id-enc="paperItem.paperIdEnc"
          :source="paperItem.source"
          :subject-code="subjectCode"
        >
          <template #reference>
            <span class="operate-item">
              <i class="iconfont iconsoutibaowangyeUIshijueyuansu-34" />
              <div class="t">分享</div>
            </span>
          </template>
        </SharePaperPopover>
      </div>
    </div>
    <div
      v-if="showMakeByCanpoint"
      class="make-by-canpoint"
    >
      <img
        :src="makeByCanpoint"
        alt=""
      >
    </div>
  </li>
</template>

<script>
  import SharePaperPopover from '@/components/PaperItem/SharePaperPopover'
  export default {
    components: { SharePaperPopover },
    props: {
      paperItem: {
        type: Object,
        require: true,
        default: () => {},
      },
      subjectCode: [String, Number],
      userGuid: Number,
      isAddBook: {
        type: Boolean,
        default: false,
      },
      showPaperView: {
        type: Boolean,
        default: false,
      },
    },
    data() {
      return {
        makeByCanpoint: require('@/assets/images/make_by_canpoint.png'),
      }
    },
    computed: {
      showMakeByCanpoint() {
        if (this.paperItem.source == 2 && this.paperItem.period == '11') {
          return true
        } else {
          return false
        }
      },
    },
    created() {},
    methods: {
      cancelShare() {
        this.$emit('cancelShare', this.paperItem)
      },
      onClickPaperShare() {
        this.$emit('onClickPaperShare', this.paperItem)
      },
      DownLoadPaper(paperItem) {
        this.$emit('onShowDownLoadPaper', this.paperItem)
      },
    },
  }
</script>

