            &:hover {
              color: #3e73cd;
            }
          }
          .t {
            font-size: 12px;
            padding-top: 8px;
          }
        }
        .operate-item:not(:last-child) {
          padding-right: 5px;
        }
      }
    }
  }
  .make-by-canpoint {
    position: absolute;
    top: -6px;
    right: -8px;
    img {
      width: 61px;
