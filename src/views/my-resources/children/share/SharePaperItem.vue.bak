            &:hover {
              color: #bababa;
            }
          }
        }
        .operate-item {
          text-align: center;
          color: $color-text-d;
          cursor: pointer;
          width: 65px;
          display: inline-block;
          & > i {
            background: #487FFF22;
            border-radius: 10px;
            padding: 10px;
            font-size: 30px;
