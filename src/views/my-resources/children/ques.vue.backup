  .user-content-right {
    width: 914px;
    background-color: transparent;

    :deep(.el-tabs .el-tabs__header) {
      // padding: 0 20px;
      margin: 0;
    }

    :deep(.el-tabs .el-tabs__header .el-tabs__nav .el-tabs__active-bar) {
