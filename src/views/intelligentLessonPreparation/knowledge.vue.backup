    :deep(.el-tabs .el-tabs__header) {
      padding: 0 20px;
    }
    :deep(.el-tabs .el-tabs__header .el-tabs__nav .el-tabs__active-bar) {
      background-color: $color-theme;
    }
    :deep(.el-tabs .el-tabs__header .el-tabs__nav .is-active) {
