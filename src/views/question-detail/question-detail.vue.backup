      line-height: 50px;
      padding-left: 20px;
      padding-top: 8px;
      border: 1px solid #eeeeee;
    }
  }
  .recommend-tabs {
    position: relative;
    padding: 0 20px;
    .recommend-btn {
      position: absolute;
      right: 20px;
      top: 0;
