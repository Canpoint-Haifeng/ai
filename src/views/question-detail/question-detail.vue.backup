      cursor: pointer;
      transition: 0.2s;
      &:hover {
        color: $color-theme-d;
      }
      .iconchange {
        display: inline-block;
        margin-right: 8px;
        font-size: $font-size-medium;
      }
    }
  }
  .tabs-content {
    @include flex();
    justify-content: flex-start;
    .recommend-label {
      width: 75px;
