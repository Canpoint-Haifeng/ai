      font-size: $font-size-medium;
      background: $color-white;
    }

    .btn-border:hover {
      border: 1px solid $color-theme;
      color: $color-theme;
    }
  }

  .item-download,
  .item-all {
    .btn {
      width: 100%;
    }
  }

  .item-all {
    .btn {
      // box-shadow:0px 2px 6px 0px rgba(42,77,138,0.18);
      color: $color-white;
    }

    .btn.btn-border {
      color: #333;
    }

    .btn.btn-border:hover {
      border: 1px solid $color-theme;
      color: $color-theme;
    }
  }

  .item-checkbox :deep(.el-checkbox__label) {
      color: $color-text;
      font-size: $font-size-small;
    }
  }

  .analysis {
    :deep(.el-button) {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;

      i {
        font-size: 20px;
        margin-right: 4px;
      }
    }

    .title {
      margin-top: 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;

      h6 {
        font-weight: bold;
        font-size: 16px;
      }

      p {
        span {
          color: #ff6900;
        }
      }
    }

    .chart {
