      font-weight: 700;
    }
  }
}

.dialog-footer {
  .btn {
    width: 100px;
    height: 34px;
    padding: 0;
  }
}

.btn-border {
  .iconfont {
    padding-right: 6px;
  }
}

.item-paper-share {
  float: right;
}
</style>
