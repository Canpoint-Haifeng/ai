  @use "@/assets/css/variables" as *;
  .user-content-right {
    width: 1200px;
    background-color: $color-white;
    margin: 0 auto;
    margin-top: 20px;
    .item-content {
      .top-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 80px;
        border-bottom: 1px solid #eeeeee;
        padding: 0 30px;

        .my-title {
          font-size: 20px;
          font-weight: 700;
          font-family: 'MicrosoftYaHei-Bold';
          color: #333333;
        }
      }

      .show-info-title {
        width: 50%;
        color: $color-text-d;
        font-size: $font-size-medium;
        font-weight: bold;
        margin-bottom: 24px;
        display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;

        span {
          display: block;
          width: 2px;
          height: 14px;
          margin-right: 20px;
          background: rgba(102, 102, 102, 1);
        }
      }
    }
  }

  .el-pagination {
    padding: 4px 5px 20px;
  }
  .pagination-container {
    text-align: center;
  }
  .wen-tip {
    margin-top: 20px;
  }

  .paper-content {
    padding: 0 30px 20px 30px;
    margin-top: 16px;
    margin-bottom: 70px;
    background: rgb(255, 255, 255);
    min-height: 450px;
  }
</style>
