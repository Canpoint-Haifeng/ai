  <div>
    <el-dialog
      v-model:visible="visible"
      title="下载教案"
      width="600px"
    >
      <div class="download_content">
        <div class="item">
          <div class="label">
            <span>下载版本：</span>
          </div>
          <div>
            <el-radio-group v-model="formData.downloadType">
              <el-radio :label="1">
                教师版
              </el-radio>
              <el-radio :label="2">
                学生版（答案解析统一放置在卷尾）
              </el-radio>
            </el-radio-group>
            <!-- <div class="tip"></div> -->
          </div>
        </div>
