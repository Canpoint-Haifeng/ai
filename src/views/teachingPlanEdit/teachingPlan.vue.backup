    changeQuestion,
    exampleBase,
    multimediaBase,
    download,
    examDirection,
    reportDialog,
    reportKnowledgeError,
    inputChat,
  },
  mixins: [mixin],
  computed: {
    ...mapState(['currSubject']),

    // hasData1() {r
    //   // 计算属性会自动追踪依赖的数据变化
    //   return (
    //     this.planTreeData&&
    //     this.planTreeData[0]&&
