    //     this.planTreeData[0].content[0].content
    //   );
    // },
    // show1(){
    //   return this.hasData1 || this.wordSignEdit1Flag;
    // },

    // showC(){
    //   return (editor, val) => {
    //   let flag = editor + "Flag";
    //   return (
    //     val &&
    //     val.content &&
    //     val.content[0] &&
    //     val.content[0].content
    //   ) || this[flag]; // 访问 this[flag] 以获取动态属性
    // };
    // },

    // showC2(){
    //   return (editor, val) => {
    //   return (
    //     val &&
    //     val.content &&
    //     val.content[0] &&
    //     !val.content[0].content
    //   )
    //   }
    // },
  },
  provide() {
    return {
      app: this,
      treeSelectInfo: () => this.treeSelectInfo,
    }
  },
  data() {
    return {
      showTab: false, //是否展示顶部tab切换
      templateList: [
        {
          name: '样式一',
          className: 'style-one',
          imgUrl: require('@/assets/images/template/template_one.png'),
        },
        {
          name: '样式二',
          className: 'style-two',
          imgUrl: require('@/assets/images/template/template_two.png'),
        },
        {
          name: '样式三',
          className: 'style-three',
          imgUrl: require('@/assets/images/template/template_three.png'),
        },
        {
          name: '样式四',
          className: 'style-four',
          imgUrl: require('@/assets/images/template/template_four.png'),
        },
        {
          name: '样式五',
          className: 'style-five',
          imgUrl: require('@/assets/images/template/template_five.png'),
        },
        {
          name: '样式六',
          className: 'style-six',
          imgUrl: require('@/assets/images/template/template_six.png'),
        },
      ],
      treeSelectInfo: {},
      showStyleSet: false,
      selectIndex: 0,
      themeStyleName: 'style-one',
      currentEditor: null,
      defaultProps: {
        children: 'child',
        label: 'name',
      },
      outlineVisible: true,
      planTreeData: [],
      knowledgeBaseVisible: false,
      examinationDirectionVisible: false,
      changeType: 0,
      questionBaseVisible: false,
      changeQuestionVisible: false,
      exampleBaseVisible: false,
      multimediaBaseVisible: false,
      downloadVisible: false,
      type: '',
      currentObj: {},
      info: {},
      lessonCondition: {},
      versionData: {},
      currentId: '',
      currentKnowledge: {},
      reviseVisible: false,
      requestNum: 0,
      requestDone: 0,
      requestLoading: false,
      examDirectionVisible: false,
      showType: '1', // 1 教学设计 2预习学案
      selectQuestionsList: [], //已选择的试题，用去筛选新增试题列表
      pointList: [],

      wordSignEdit1Flag: true,
      wordSignEdit2Flag: false,
      wordSignEdit3Flag: true,
      wordSignEdit4Flag: true,
      wordSignEdit5Flag: true,
      wordSignEdit6Flag: true,
      wordSignEdit7Flag: true,
      wordSignEdit8Flag: true,

      popoverX: 1,
      popoverY: 1,
      curChatParent: {},
      curKonwledgeList: [],
      chatAiVisible: false,
    }
  },
  watch: {
    showType(val) {
      window.scrollTo(0, 0)
    },
    questionBaseVisible(newVal) {
      if (newVal) {
        this.selectQuestionsList = this.questionList()
      }
    },
    selectIndex(newVal) {
      this.themeStyleName = this.templateList[newVal].className
    },
  },

  mounted() {
    this.reviseVisible = !!this.$route.query.revise
    this.$store.dispatch('getVersionGrade', { vm: this, reload: true })
    this.type = this.$route.query.type || 1
    this.showType = this.type == 1 ? '2' : '1'
    // if(this.type) {
    //     this.planTreeData[0] = [{label: '知识结构', visible: true, anchor: 't01'}]
    // }
    // this.getTemplateData()

    this.getLessonDetail().then(() => {
      this.$nextTick(() => {
        if (this.$route.query.manual) {
          this.examinationDirectionVisible = true
        }
      })
    })

    this.Bus.$on('referenceError', info => {
      this.$nextTick(() => {
        this.$refs.reportDialog && this.$refs.reportDialog.showDialog(info)
      })
    })

    document.addEventListener('click', this.handleClickOutside)
    window.addEventListener('wheel', this.handleScroll)
  },
  beforeUnmount() {
    document.removeEventListener('click', this.handleClickOutside)
    window.removeEventListener('wheel', this.handleScroll)
    this.chatAiVisible = false
  },
  methods: {
    knowledgeReport(val) {
      this.$refs.konwledegError && this.$refs.konwledegError.showDialog(val)
    },
    //获取试题列表
    questionList() {
      const getQuestionUuids = nodes => {
        let uuids = []
        if (!nodes) return uuids

        nodes.forEach(node => {
          // 检查节点级别的 childRule
          if (node.childRule && node.childRule.defaultDataType === 2) {
            // 处理当前节点的 content
            if (node.content) {
              uuids = uuids.concat(
                node.content
                  .filter(
                    item =>
                      item.generalQuestionVo &&
                      item.generalQuestionVo.questionId,
                  )
                  .map(item => item.generalQuestionVo.questionId),
              )
            }
          }

          // 递归处理子节点
          if (node.child && node.child.length) {
            uuids = uuids.concat(getQuestionUuids(node.child))
          }
        })

        return uuids
      }

      return getQuestionUuids(this.info.outline || [])
    },

    getKnowledgeNumber(str) {
      const regex = /知识点(\d+):/
      const match = str.match(regex)
      return match ? match[1] : ''
    },
    quesSetExam(item, a, b, flag) {
      if (flag === 'out') {
        // 设为课外
        const target1 = a.child.find(i => {
          return i.name.includes('课后作业')
        })
        if (target1) {
          target1.content = target1.content || []
          if (target1.content.length === 1) {
            const firstItem = target1.content[0]
            if (
              !firstItem.generalQuestionVo ||
              Object.keys(firstItem.generalQuestionVo).length === 0
            ) {
              firstItem.generalQuestionVo = item[0].generalQuestionVo
            } else {
              target1.content.push(item[0])
            }
          } else {
            target1.content.push(item[0])
          }
        }
      }
      if (flag === 'inner') {
        const target2 = a.child.find(i => {
          return i.name.includes('课内练习')
        })

        target2.content = target2.content || []
        if (target2.content.length === 1) {
          const firstItem = target2.content[0]
          if (
            !firstItem.generalQuestionVo ||
            Object.keys(firstItem.generalQuestionVo).length === 0
          ) {
            firstItem.generalQuestionVo = item[0].generalQuestionVo
          } else {
            target2.content.push(item[0])
          }
        } else {
          target2.content.push(item[0])
        }
      }
      this.$set(item, 0, { ...item[0], generalQuestionVo: {} }) // 清空例题的数据
      // a.content.splice(0, 1);
    },
    quesSet(item, t, c, d, a, y, b, index, flag) {
      if (flag == 'example') {
        // 设为例题
        a.content.splice(0, 1, item) // 替换例题项
      }
      if (flag === 'out') {
        // 设为课外
        const target1 = a.child.find(i => {
          return i.name.includes('课后作业')
        })
        // if (target1) {
        //   if (target1.content) {
        //     target1.content.push(item)
        //   } else {
        //     this.$set(target1, 'content', [item])
        //   }
        // }

        target1.content = target1.content || []
        if (target1.content.length === 1) {
          const firstItem = target1.content[0]
          if (
            !firstItem.generalQuestionVo ||
            Object.keys(firstItem.generalQuestionVo).length === 0
          ) {
            firstItem.generalQuestionVo = item.generalQuestionVo
          } else {
            target1.content.push(item)
          }
        } else {
          // this.$set(target1, 'content', [item])
          target1.content.push(item)
        }
      }
      if (flag == 'inner') {
        const target2 = a.child.find(i => {
          return i.name.includes('课内练习')
        })

        if (target2) {
          // if (target2.content) {
          //   target2.content.push(item)
          // } else {
          //   this.$set(target2, 'content', [item])
          // }

          target2.content = target2.content || []
          if (target2.content.length === 1) {
            const firstItem = target2.content[0]
            if (
              !firstItem.generalQuestionVo ||
              Object.keys(firstItem.generalQuestionVo).length === 0
            ) {
              firstItem.generalQuestionVo = item.generalQuestionVo
            } else {
              target2.content.push(item)
            }
          } else {
            target2.content.push(item)
          }
        }
      }
      // 删除当前项
      if (c.content.length === 1) {
        this.$set(c.content, 0, { ...c.content[0], generalQuestionVo: {} })
      } else {
        c.content.splice(index, 1)
      }
    },
    //选择模版样式
    selectTemplate(index) {
      this.selectIndex = index
    },
    aiGeneration() {
      if (this.requestLoading) {
        return this.$message.warning('正在生成中')
      }
      this.requestDone = 0
      this.requestLoading = true
      this.generationFn()
    },
    generationFn(arr = this.planTreeData, parent) {
      arr.forEach(item => {
        item.pNmae = parent ? parent.name : ''
        this.getGenerationData(item)
        item.child.length && this.generationFn(item.child, item)
      })
    },
    getGenerationData(v) {
      let knamesStr = (this.curKonwledgeList || [])
        .map(item => item.name)
        .join(',') // 知识点名字
      if (
        /(知识结构|预习目标|预习任务|教学目标|重点难点|教学方法|新课导入|知识梳理|解法探究|教学总结)/i.test(
          v.name,
        )
      ) {
        // const str = `生成${this.currSubject.periodName}${this.currSubject.subjectName}知识点点为${this.currentKnowledge.name}200字左右的${v.name}备课内容`
        const str = this.demand(
          v.name,
          /(知识梳理|解法探究)/.test(v.name) ? v.pNmae : knamesStr,
        )
        this.newPost(
          { urlPath: '/lesson-app/douBao/questionsAnswerDialogue' },
          str,
        )
          .then(res => {
            res.data && (v.content[0].content = res.data)
            if (res.data) {
              // v.content[0].content = res.data.split('---')[1]
              v.content[0].content = v.content[0].content.replace(/\n/g, '<br>')
              if (v.name !== '教学总结') {
              }
            }
          })
          .finally(() => {
            this.requestDone++
            this.requestLoading = this.requestDone < this.requestNum
          })
      }
    },
