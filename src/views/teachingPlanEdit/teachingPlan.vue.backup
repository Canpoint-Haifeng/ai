    bb(v) {
      localStorage.setItem('bb', JSON.stringify(v))
    },
    getLessonDetail() {
      return new Promise((resolve, reject) => {
        const data = {
          lessonId:
            this.$route.query.id || '010b1830-0cc4-2182-a198-041405116418',
          lessonType: this.$route.query.type || 1,
          source: this.$route.query.source || 2,
        }
        this.apiPost({ urlPath: '/lesson-app/myLesson/lessonDetail' }, data, {
          showLoading: true,
        }).then(res => {
          if (res.code !== 200) return
          this.selectIndex = res.data.style ? res.data.style * 1 : 0

          this.showTab = res.data.lessonType == 1
          if (
            res.data.stageId !== this.currSubject.periodCode ||
            res.data.subjectId !== this.currSubject.subjectCode
          ) {
            this.$router.replace(
              `/manualPrepare?type=${this.$route.query.type}`,
            )
            return
          }
          this.apiGet(
            { urlPath: '/lesson-app/lessonApp/getLessonCondition' },
            { lessonInfoId: res.data.id },
          ).then(res => {
            if (res.code === 200) {
              if (res.data && res.data.details) {
                console.log(JSON.parse(res.data.details))
                this.lessonCondition = res.data
                this.versionData = JSON.parse(res.data.details)
                this.currentKnowledge = this.versionData.knowLedgeList[0]
                this.curKonwledgeList = this.versionData.knowLedgeList || []
              } else {
                this.lessonCondition = {}
                this.versionData = {}
                this.currentKnowledge = {}
              }
            }
            resolve(1)
          })
          let requestNum = 0
          function format(arr) {
            arr.forEach(item => {
              if (
                [
                  '教学规划',
                  '教学目标',
                  '重点难点',
                  '教学方法',
                  '教学过程',
                  '新课导入',
                  '知识梳理',
                  '解法探究',
                  '教学总结',
                ].includes(item.name)
              ) {
                item.icon = 'view'
              }
              if (
                /(知识结构|预习目标|预习任务|教学目标|重点难点|教学方法|新课导入|知识梳理|解法探究|教学总结)/i.test(
                  item.name,
                )
              ) {
                requestNum++
              }
              // if(/[知识点|考向|课后作业|课内练习|例题]/.test(item.name)) {
              //     item.icon = 'del'
              // }
              item.icon = item.icon || 'del'
              if (item.content && !item.content.length) {
                item.content = [
                  {
                    content: '',
                    lessonInfoId: item.lessonInfoId,
                    lessonOutlineId: item.id,
                  },
                ]
              }
              item.content.forEach(v => {
                let type = 1
                if (
                  /(知识结构|预习目标|预习任务|预习填空|教学目标|重点难点|教学方法|新课导入|解法探究|教学总结)/i.test(
                    item.name,
                  )
                ) {
                  type = 2
                }
                if (item.name === '知识梳理') {
                  type = 3
                }
                // if(/(例题)/i.test(item.name)) {
                //     type = 4
                // }
                delete v.questionVo
                v.sourceType = v.sourceType || type
              })
              // if (/(基础检测|拔高检测)/i.test(item.name)) {
              //     item.content = item.content.filter(v => v.generalQuestionVo)
              //     console.log(item.content)
              // }
              if (item.child && item.child.length) {
                format(item.child)
              }
            })
          }
          format(res.data.outline)
          this.requestNum = requestNum
          this.info = res.data
          this.planTreeData = res.data.outline
          // console.log(this.planTreeData.at(-1))
          // console.log(this.planTreeData[0].child[0])
        })
      })
    },
