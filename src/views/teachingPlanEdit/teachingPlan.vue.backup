<template>
  <div class="teaching_plan_edit">
    <div class="head">
      <div class="back">
        <el-button
          type="primary"
          size="medium"
          plain
          icon="iconfont icon-goback"
          @click="exit"
        >
          退出编辑
        </el-button>
      </div>
      <div class="center">
        <el-button
          type="text"
          size="medium"
          icon="el-icon-circle-plus"
          @click="addExaminationDirection"
        >
          选择备课范围
        </el-button>
      </div>
      <div class="tab-box">
        <el-radio-group
          v-if="showTab"
          v-model="showType"
        >
          <el-radio-button label="2">
            预习学案
          </el-radio-button>
          <el-radio-button label="1">
            教学设计
          </el-radio-button>
        </el-radio-group>
      </div>
      <div class="save_download">
        <!-- <em v-if="requestLoading">生成中...</em> -->
        <el-button
          v-if="requestLoading"
          type="primary"
          :loading="true"
        >
          生成中
        </el-button>
        <!-- <p>{{ requestNum }}---{{ requestDone }}</p> -->
        <div
          v-else
          class="ai-start-btn"
          @click="aiGeneration"
        >
          <img
            src="../../assets/images/ai/ai-start.png"
            alt="AI备课"
          >
          AI备课
        </div>
        <el-button
          type="primary"
          size="medium"
          plain
          icon="iconfont icon-save_2_line"
          @click="save(1)"
        >
          保存教案
        </el-button>
        <el-button
          v-if="reviseVisible"
          type="primary"
          size="medium"
          @click="revise"
        >
          提交修订
        </el-button>
        <el-button
          v-else
          type="primary"
          size="medium"
          icon="iconfont icon-plus-download"
          @click="download"
        >
          下载教案
        </el-button>
      </div>
    </div>
    <div
      v-if="planTreeData.length"
      class="main"
    >
      <div class="structure">
        <section>
          <el-button
            class="switch"
            type="text"
            size="medium"
            @click="outlineVisible = !outlineVisible"
          >
            {{ outlineVisible ? '收起' : '展开' }}
            <i
              class="iconfont"
              :class="outlineVisible ? 'icon-shouqi' : 'icon-zhankai'"
            />
          </el-button>
          <transition name="outline">
            <div
              v-if="outlineVisible"
              class="outline"
            >
              <div class="head">
                <h6>教案结构</h6>
              </div>
              <div class="tree">
                <div
                  v-if="showType == 2"
                  class="plan"
                >
                  <el-tree
                    ref="plantree"
                    :data="[planTreeData[0]]"
                    default-expand-all
                    :expand-on-click-node="false"
                    :props="defaultProps"
                  >
                    <template #default="{ node, data }">
                      <div
                        class="custom-tree-node"
                        @click="handleNodeClick(data)"
                      >
                        <span>{{ data.name }}</span>
                        <div @click.stop="aa(data, node)">
                          <i
                            class="iconfont"
                            :class="data.isShow === 1 ? 'icon-view' : 'icon-hide'"
                            @click="toggleNode(data, node)"
                          />
                        </div>
                      </div>
                    </template>
                  </el-tree>
                </div>
                <div
                  v-else
                  class="design"
                >
                  <p>教学设计</p>
                  <!-- :filter-node-method="filterNode" -->
                  <el-tree
                    ref="tree"
                    :data="planTreeData[1].child"
                    default-expand-all
                    :expand-on-click-node="false"
                    :props="defaultProps"
                  >
                    <template #default="{ node, data }">
                      <div
                        class="custom-tree-node"
                        @click="handleNodeClick(data)"
                      >
                        <span :title="data.showName">{{
                          data.showName || data.name
                        }}</span>
                        <div
                          v-if="data.icon === 'del'"
                          @click.stop="delNode(data, node)"
                        >
                          <i class="el-icon-delete" />
                        </div>
                        <!--  v-if="data.icon === 'view'" -->
                        <div @click.stop="aa(data, node)">
                          <i
                            class="iconfont"
                            :class="data.isShow === 1 ? 'icon-view' : 'icon-hide'"
                            @click="toggleNode(data, node)"
                          />
                        </div>
                      </div>
                    </template>
                  </el-tree>
                </div>
              </div>
            </div>
          </transition>
        </section>
      </div>
