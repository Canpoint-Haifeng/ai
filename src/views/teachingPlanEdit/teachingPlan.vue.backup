    toggleNode(v, node) {
      v.isShow = v.isShow === 1 ? 2 : 1
      // 递归更新所有子节点的 isShow
      const updateChildren = (nodes, isShow) => {
        if (!nodes || !nodes.length) return
        nodes.forEach(item => {
          item.isShow = isShow
          if (item.child && item.child.length) {
            updateChildren(item.child, isShow)
          }
        })
      }
      // 递归调用
      if (v.child && v.child.length) {
        updateChildren(v.child, v.isShow)
      }
    },
    filterNode(value, data) {
      console.log(data.del)
      console.log(!data.del, data.label)
      return !data.del
    },
    async delNode(v, y) {
      const index = y.parent.data.child.findIndex(item => item.name === v.name)
      y.parent.data.child.splice(index, 1)
      await this.save()
      await this.getLessonDetail()

      // v.del = true
      // this.$refs.tree.filter();
    },
    hideItem(v, i) {
      // this.$set(v, i, {...v[i], del: true})
      // this.$refs.tree.filter();
      v.splice(i, 1)
    },
    async delItem(v, i, flag) {
      if (flag && flag == 'knowledge') {
        const newArr = v.slice(0, i - 1).concat(v.slice(i)) || []
        this.$set(this.planTreeData[1].child[1], 'child', newArr)
        await this.save()
        await this.getLessonDetail()
      } else if (flag && flag == 'point') {
        v.splice(i, 1)
        await this.save()
        await this.getLessonDetail()
      } else {
        v.splice(i, 1)
      }
    },
    handleNodeClick(v) {
      // console.log(v)
      const dom = document.getElementById(`t${v.id}`)
      // dom&&dom.scrollIntoView({behavior: "smooth", block: "start", inline: "nearest"})
      dom &&
        window.scrollTo({
          top: dom.getBoundingClientRect().top + window.scrollY - 60,
          behavior: 'smooth',
        })
    },
    aa(a, b) {
      console.log(a, b)
    },
    setKnowledge(v) {
      this.currentKnowledge = {
        ...v,
        id: v.chapterCode,
      }
    },
    addExaminationDirection() {
      if (!this.verify()) return
      this.save()
      this.examinationDirectionVisible = true
    },
    updataCkEditorData(v, str) {
      v.content = str
      // console.log(this.$refs.wordSignEdit.resultCkEditorData())
    },

    handleScroll(event) {
      this.chatAiVisible = false
    },
    handleClickOutside(event) {
      const popoverEl =
        (this.$refs.popoverBox && this.$refs.popoverBox.$el) ||
        this.$refs.popoverBox
      if (popoverEl && popoverEl.contains(event.target)) {
        return
      }
      this.chatAiVisible = false
    },
    changeShow(editor) {
      let flag = editor + 'Flag'
      this[flag] = false
    },
    editAddClick(editor) {
      let flag = editor + 'Flag'
      this[flag] = true
      this.$set(this, flag, true)

      if (Array.isArray(this.$refs[editor]) && this.$refs[editor][0]) {
        this.$refs[editor][0].editorClick()
      } else {
        this.$refs[editor].editorClick()
      }

      // this.wordSignEdit2Flag = true
      // this.$refs[editor] && this.$refs[editor].editorClick()
    },

    getContent(content) {
      if (content) {
        content = content.replace(/(\r?\n)+/g, '<br/>')
        return content
      }
    },

    // 单个生成方式
    async createContent(str) {
      try {
        const res = await this.newPost(
          { urlPath: '/lesson-app/douBao/questionsAnswerDialogue' },
          str,
        )
        if (res.code == 200) {
          return this.getContent(res.data) || ''
        } else {
          this.$message.error(res.msg)
          return ''
        }
      } catch (error) {
        console.error('请求失败:', error)
        return ''
      }
    },

    async onSelectAi(val) {
      const curParent = this.curChatParent
      const curContent = this.currentObj.content
      let knamesStr = (this.curKonwledgeList || [])
        .map(item => item.name)
        .join(',') // 知识点名字
      if (this.curChatOuter && /(知识梳理|解法探究)/.test(curParent.name)) {
        knamesStr = this.curChatOuter.name
      }
      let str = this.demand(curParent.name, knamesStr)
      str += `
        # 现有内容为 【${curContent}】 
        # 请根据要求 【${val}】 
        # 输出(Output) - 合理运用 markdown 格式，将你的回复进行结构化呈现
        `
      if (
        /(知识结构|预习目标|预习任务|教学目标|重点难点|教学方法|新课导入)/i.test(
          curParent.name,
        )
      ) {
        try {
          const res = await this.createContent(str)
          if (res) {
            this.currentObj.content += `<br />${res}`
          }
        } catch (error) {
          console.error('生成内容失败:', error)
        }
      }
    },
    //  ai 按钮
    chatAIChange(content, val, i, parent, flag, event) {
      event.stopPropagation()
      // 计算弹框位置
      this.popoverX = event.clientX - 400
      this.popoverY = event.clientY + 30

      this.curChatParent = content // 当前数据的父节点
      this.currentObj = val // 当前需要修改的数据
      if ((flag && flag == 'jftj') || flag == 'zssl') {
        // 数据结构不同，特殊处理一下
        this.curChatOuter = parent
      } else {
        this.curChatOuter = null
      }

      // this.changeType = i
      this.chatAiVisible = true
    },
    changeContent(v, i) {
      this.currentObj = v
      this.changeType = i
      this.knowledgeBaseVisible = true
    },
    addQuestion(v, id) {
      console.log('添加试题===', v, id)
      this.currentObj = v
      this.currentId = id
      this.questionBaseVisible = true
      console.log(this.questionBaseVisible)
    },
    addMaterial() {
      this.multimediaBaseVisible = true
    },
    changeExample(v, i, type) {
      if (type === 'change') {
        this.changeQuestion(v, i, '', type)
      }
      console.log(v[i].generalQuestionVo, type)
      if (type === 'del') {
        this.$set(v, i, { ...v[i], generalQuestionVo: {} })
        // v[i].generalQuestionVo = {}
      }
    },

    questionUp(queslist, index, type) {
      if (index > 0 && index < queslist.length) {
        queslist.splice(index - 1, 2, queslist[index], queslist[index - 1])
      }
    },
    questionDown(queslist, index, type) {
      if (index >= 0 && index < queslist.length - 1) {
        queslist.splice(index, 2, queslist[index + 1], queslist[index])
      }
    },
    changeQuestion(v, i, parent, type) {
      if (type === 'change') {
        // 添加
        this.currentObj = v[i]
        this.changeQuestionVisible = true
      }
      if (type === 'del') {
        if (v.length === 1) {
          // this.$message.warning('至少保留一个题目')
          // v[i].generalQuestionVo = {}
          // v[i] = { ...v[i], generalQuestionVo: {} };
          this.$set(v, i, { ...v[i], generalQuestionVo: {} })
          return
        }
        v.splice(i, 1)
        // this.deleteOutlineContent(v[i].id, 2)
      }
      if (type === 'up') {
        this.questionUp(v, i, type)
      }
      if (type === 'down') {
        this.questionDown(v, i, type)
      }
    },
    selectQuestion(v) {
      //对于替换试题，替换后关闭便于重新获取需要排除的选中试题，对于push可以连续选择
      console.log('选题', this.currentObj)
      this.selectQuestionsList.push(v.questionId)
      if (this.currentObj.type === 'example') {
        this.addExamQuestion(v)
        this.closeDialog()
      }
      if (this.currentObj.length) {
        const item = {
          generalQuestionVo: v,
          label: this.currentObj.length + 1,
          sourceType: 1,
          lessonInfoId: this.info.id,
          lessonOutlineId: this.currentId,
        }
        if (this.currentObj.length === 1) {
          const firstItem = (this.currentObj && this.currentObj[0]) || {}
          if (
            !firstItem.generalQuestionVo ||
            Object.keys(firstItem.generalQuestionVo).length === 0
          ) {
            firstItem.generalQuestionVo = v
          } else {
            this.currentObj.push(item)
          }
        } else {
          this.currentObj.push(item)
        }
      } else {
        this.currentObj.generalQuestionVo = v
        this.closeDialog()
      }
      console.log(this.currentObj)
      //this.closeDialog()
    },
    selectKnowledge(v) {
      console.log(v)
      this.currentObj.content = v
      console.log(this.currentObj)
      this.closeDialog()
    },
    addExampleModule(v) {
      if (!this.verify()) return
      this.save()
      this.currentObj = v
      this.questionBaseVisible = true
    },
    addExamQuestion(v) {
      const data = {
        lessonInfoId: this.info.id,
        outlineId: this.currentObj.id,
        questionId: v.questionId,
      }
      this.newPost({ urlPath: '/lesson-app/lessonApp/addExamQuestion' }, data, {
        showLoading: true,
      }).then(res => {
        if (res.code === 200) {
          this.getLessonDetail()
        } else {
          this.$message.error(res.msg)
        }
      })
    },
    changeExampleModule(v) {
      this.currentObj = v
      this.exampleBaseVisible = true
    },
    selectExample(v) {
      const data = {
        lessonInfoId: this.info.id,
        outlineId: this.currentObj.id,
        pieceOutline: { ...v.outline, ...v.pieceInfo },
      }
      this.newPost(
        { urlPath: '/lesson-app/material/replacePieceOutline' },
        data,
        {
          showLoading: true,
        },
      ).then(res => {
        if (res.code === 200) {
          this.$message.success('操作成功')
          this.closeDialog()
          this.getLessonDetail()
        } else {
          this.$message.error(res.msg)
        }
      })
    },

    getExamPoint(val) {
      let params = {
        lessonInfoId: this.info.id,
        knowledgeId: val.chapterCode,
      }
      this.apiGet(
        { urlPath: '/lesson-app/lessonApp/getKnowledgeNext' },
        params,
        { showLoading: true },
      ).then(res => {
        if (res.code == 200) {
          this.pointList = res.data || []

          this.examDirectionVisible = true
        }
      })
    },
    async onPointChange(val) {
      await this.save()
      let arr = this.pointList.filter(item => val.includes(item.uuid))
      const newArr = arr.map(v => {
        return { ...v, type: 2, id: v.uuid }
      })
      let temArr = [
        {
          name: this.currentObj.name,
          id: this.currentObj.chapterCode,
          type: 1,
          // importance:0,
          children: newArr,
        },
      ]
      const data = {
        lessonGenerateType: this.$route.query.lessonType || 1,
        lessonInfoId: this.info.id,
        knowledgeList: temArr,
        lessonConditionBo: {},
      }
      this.newPost({ urlPath: '/lesson-app/lessonApp/addKnowledge' }, data, {
        showLoading: true,
      }).then(res => {
        if (res.code === 200) {
          this.getLessonDetail()
          this.$message.warning('请添加新增考向下的试题')
        } else {
          this.$message.error(res.msg)
        }
      })
    },

    addExamDirection(v) {
      this.getExamPoint(v)
      this.currentObj = v
      console.log(v)
    },
    closeDialog() {
      this.knowledgeBaseVisible = false
      this.questionBaseVisible = false
      this.multimediaBaseVisible = false
      this.exampleBaseVisible = false
      this.changeQuestionVisible = false
      this.examinationDirectionVisible = false
      this.examDirectionVisible = false
    },
    selectGrade(info) {
      console.log('0000', info)
      this.treeSelectInfo = info
    },
    submitExaminationDirection(arr) {
      this.closeDialog()
      this.getLessonDetail()
      return
      const knowledge = this.planTreeData[1][1].children
      const uuid = knowledge.slice(1).map(v => v.uuid)
      const res = []
      arr.forEach(v => {
        if (uuid.includes(v.uuid)) {
          const i = uuid.findIndex(y => y === v.uuid)
          const item = { ...knowledge[i + 1], children: [] }
          v.children.forEach(y => {
            const child = knowledge[i + 1].children.find(
              z => z.uuid === y.uuid,
            ) || {
              label: y.name,
              uuid: y.uuid,
              visible: true,
              anchor: 't' + y.uuid,
              icon: 'del',
              children: [{ label: '解法探究', visible: true, icon: 'view' }],
            }
            item.children.push(child)
          })
          res.push(item)
        } else {
          const item = {
            label: v.name,
            uuid: v.uuid,
            visible: true,
            anchor: 't' + v.uuid,
            icon: 'del',
            children: [
              { label: '知识梳理', visible: true, icon: 'view' },
              ...v.children.map(y => {
                return {
                  label: y.name,
                  uuid: y.uuid,
                  visible: true,
                  anchor: 't' + y.uuid,
                  icon: 'del',
                  children: [
                    { label: '解法探究', visible: true, icon: 'view' },
                  ],
                }
              }),
            ],
          }
          res.push(item)
        }
      })
      this.planTreeData[1][1].children = [knowledge[0], ...res]
      console.log(this.planTreeData[1][1].children)
      this.closeDialog()
    },
    deleteOutlineContent(id, type) {
      const data = {
        id,
        type,
      }
      this.newPost(
        { urlPath: '/lesson-app/lessonApp/deleteOutlineContent' },
        data,
      ).then(res => {
        this.getLessonDetail()
      })
    },
    verify() {
      if (!this.info.title) {
        this.$message.warning('请输入教案名称')
        return false
      }
      if (!this.info.subTitle) {
        this.$message.warning('请输入教案标题')
        return false
      }
      return true
    },
    save(v) {
      this.info.style = this.selectIndex
      const data = {
        lessonConditionBo: this.lessonCondition,
        lessonVo: this.info,
      }
      this.newPost({ urlPath: '/lesson-app/lessonApp/saveLesson' }, data, {
        showLoading: true,
      }).then(res => {
        if (res.code === 200) {
          v && this.$message.success('教案保存成功')
        } else {
          this.$message.error(res.msg)
        }
      })
    },
    download() {
      if (!this.verify()) return
      this.save()
      this.downloadVisible = true
    },
    exit() {
      this.$router.go(-1)
    },
    revise() {
      const data = {
        lessonInfoId: this.info.id,
      }
      this.apiPost({ urlPath: '/lesson-app/backstage/submitModify' }, data, {
        showLoading: true,
      }).then(res => {
        if (res.code === 200) {
          this.$message.success('操作成功')
        } else {
          this.$message.error(res.msg)
        }
      })
    },

    // hasData2() {
    //     return (
    //       this.planTreeData&&
    //       this.planTreeData[0]&&
    //       this.planTreeData[0].child&&
    //       this.planTreeData[0].child[0]&&
    //       this.planTreeData[0].child[0].content &&
    //       this.planTreeData[0].child[0].content[0] &&
    //       this.planTreeData[0].child[0].content[0].content
    //     );
    //   },
    //   show2(){
    //     return this.hasData2 || this.wordSignEdit2Flag;
    //   },
    //   hasData2(val) {
    //     return (
    //       val&&
    //       val.content&&
    //       val.content[0]&&
    //       val.content[0].content
    //     );
    //   },

    // showC(editor,val){
    //    let flag = editor + 'Flag'
    //   return this.hasData2(val) || this[flag];
    // },

    // showC2(editor,val){
    //   return !this.hasData2(val) ;
    // },
  },
}
</script>
<style>
<style lang="scss" scoped>
@import "@/assets/css/mixins.scss";
@import "@/assets/css/variables.scss";
@import "@/assets/css/variables.scss";
.cke_top {
  background: #fff !important;
}
@mixin bg($bg) {
  background: url('../../assets/images/template/'+$bg) no-repeat;
  background-size: 100% 100%;
  background-repeat: no-repeat;
}
@mixin base-style {
  .children-title {
    width: 350px;
    height: 50px;
  }

  .example-question {
    width: 56px;
    height: 28px;
    background: #999;
    color: #fff;
    text-align: center;
    line-height: 28px;
    border-radius: 28px / 14px;
  }
  .knowledge-points {
    min-width: 340px;
    width: fit-content;
    height: 28px;
    border-radius: 4px;
    color: #333;
    display: flex;
    font-size: 18px;
    line-height: 28px;
    padding: 0 10px;
    box-sizing: border-box;
    .point-til {
      font-size: 16px;
      font-weight: normal;
    }
    .point-index {
      width: 32px;
      height: 32px;
      line-height: 32px;
      font-size: 16px;
      border-radius: 4px;
      text-align: center;
      margin: 0 6px;
      transform: translateY(-2px);
    }
  }
  .examination-place {
    display: flex;
    align-items: center;
    font-size: 16px;
    margin-right: 10px;
    .exam-point {
      display: flex;
      width: 100px;
      height: 24px;
      border-radius: 8px;
      align-items: center;
      justify-content: center;
      margin-right: 20px;
      .exam-index {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: block;
        text-align: center;
        line-height: 28px;
        margin-left: 10px;
      }
    }
  }
  .practice-title {
    width: 80px;
    height: 24px;
    background: rgba(72, 127, 255, 0.2);
    text-align: center;
    line-height: 24px;
    position: relative;
    &::before {
      content: '';
      width: 0;
      height: 0;
      border-top: 12px solid transparent;
      border-right: 9px solid rgba(72, 127, 255, 0.2);
      border-bottom: 12px solid transparent;
      position: absolute;
      left: -9px;
    }
    &::after {
      content: '';
      width: 0;
      height: 0;
      border-top: 12px solid transparent;
      border-left: 9px solid rgba(72, 127, 255, 0.2);
      border-bottom: 12px solid transparent;
      position: absolute;
      right: -9px;
    }
  }
}

@mixin theme-backgrounds($theme) {
  .part-one {
    @include bg('#{$theme}/jxjh.png');
  }
  .jxgh-title {
    @include bg('#{$theme}/jxgh.png');
  }
  .jxmb-title {
    @include bg('#{$theme}/jxmb.png');
  }
  .zdnd-title {
    @include bg('#{$theme}/zdnd.png');
  }
  .jxff-title {
    @include bg('#{$theme}/jxff.png');
  }
  .jxgc-title {
    @include bg('#{$theme}/jxgc.png');
    width: 240px;
    height: 60px;
  }
  .zssl-title {
    @include bg('#{$theme}/zssl.png');
  }
  .jftj-title {
    @include bg('#{$theme}/jftj.png');
  }
  .jxzj-title {
    @include bg('#{$theme}/jxzj.png');
  }
  .part-two {
    @include bg('#{$theme}/yxxa.png');
  }
  .zsjg-title {
    @include bg('#{$theme}/zsjg.png');
  }
  .yxmb-title {
    @include bg('#{$theme}/yxmb.png');
  }
  .yxrw-title {
    @include bg('#{$theme}/yxrw.png');
  }
  .yxtk-title {
    @include bg('#{$theme}/yxtk.png');
  }
  .yxjc-title {
    @include bg('#{$theme}/yxjc.png');
  }
}
@mixin font-color($fontColor, $bgColor) {
  .knowledge-points {
    background: $bgColor;
    .point-index {
      color: #fff;
      background: $fontColor;
    }
  }
  .examination-place {
    .exam-point {
      background: $fontColor;
      color: #fff;
      .exam-index {
        background: #ffff;
        color: $fontColor;
      }
    }
  }
}
.style-one {
  @include base-style;
  @include font-color(#56a2ff, rgba(86, 162, 255, 0.1));
  @include theme-backgrounds('styleOne');
}
.style-two {
  @include base-style;
  @include font-color(#c21318, rgba(194, 19, 24, 0.1));
  @include theme-backgrounds('styleTwo');
}
.style-three {
  @include base-style;
  @include font-color(#4b7fff, rgba(72, 127, 255, 0.1));
  @include theme-backgrounds('styleThree');
}

.style-four {
  @include base-style;
  @include font-color(#487fff, rgba(72, 127, 255, 0.1));
  @include theme-backgrounds('styleFour');
}
.style-five {
  @include base-style;
  @include font-color(#ab92ff, rgba(238, 233, 255, 0.1));
  @include theme-backgrounds('styleFive');
}
.style-six {
  @include base-style;
  @include font-color(#7d9bff, rgba(125, 155, 255, 0.1));
  @include theme-backgrounds('styleSix');
}
.holder {
  margin-left: 16px;
  position: relative;
  .style-set {
    position: absolute;
    z-index: 1;
    cursor: pointer;
    width: 88px;
    height: 40px;
    background: #ffffff;
    box-shadow: 3px 5px 20px 1px rgba(42, 77, 138, 0.16);
    border-radius: 10px;
    font-size: 12px;
    color: #487fff;
    display: flex;
    align-items: center;
    justify-content: center;
    &::after {
      content: '';
      width: 20px;
      height: 20px;
      display: block;
      margin-left: 4px;
      background: url(../../assets/images/paint_brush_line.png) 0 0 no-repeat;
    }
  }
  .template-box {
    background: #ffffff;
    box-shadow: 3px 5px 20px 1px rgba(42, 77, 138, 0.3);
    border-radius: 10px 10px 10px 10px;
    height: 100%;
    transition: all 0.3s;
    .template-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid #e2e2e2;
      height: 60px;
      line-height: 60px;
      padding: 0 20px;
      box-sizing: border-box;
      .template-til {
        display: flex;
        align-items: center;
        b {
          display: block;
          height: 20px;
          width: 4px;
          border-radius: 2px;
          background: #487fff;
          margin-right: 10px;
        }
      }
      .close-btn {
        cursor: pointer;
      }
    }

    .template-list {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-around;
      padding: 24px 20px;
      box-sizing: border-box;
      .template-item {
        margin-bottom: 10px;
        .template-img {
          width: 120px;
          height: 180px;
          border-radius: 4px 4px 4px 4px;
          border: 1px solid #e2e2e2;
          position: relative;
          img {
            width: 100%;
          }
        }
        .select-icon {
          color: #487fff;
          position: absolute;
          bottom: 12px;
          right: 12px;
          display: none;
        }
        .template-name {
          width: 100%;
          margin-top: 10px;
          text-align: center;
        }
      }
    }
    .active {
      .template-img {
        border: 1px solid #487fff !important;
        .select-icon {
          display: block;
        }
      }
    }
  }
}
.tab-box {
  flex: 1;
  display: grid;
  place-items: center; /* 水平和垂直居中 */
}
.teaching_plan_edit {
  .title {
    line-height: 1;
    margin: 0;
